{
  "info": {
    "name": "Tugas 9 - Todo API (NestJS + MySQL + TypeORM)",
    "description": "Koleksi testing endpoint Todo API. Jalankan berurutan dari atas ke bawah pada database kosong (todo pertama akan mendapat id=1, todo kedua id=2, dst).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Create Todo - Valid (lengkap)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Belajar NestJS\",\n  \"description\": \"Menyelesaikan modul TypeORM dan validasi DTO\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2026-07-20\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/todos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos"] },
        "description": "Ekspektasi: 201 Created, response berisi todo baru dengan id=1."
      }
    },
    {
      "name": "2. Create Todo - Valid (title saja, priority default)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Beli bahan praktikum\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/todos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos"] },
        "description": "Ekspektasi: 201 Created, id=2, priority otomatis 'low' (default dari Entity)."
      }
    },
    {
      "name": "3. Create Todo - Invalid (title kosong)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/todos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos"] },
        "description": "Ekspektasi: 400 Bad Request, message 'title tidak boleh kosong'. Menguji @IsNotEmpty."
      }
    },
    {
      "name": "4. Create Todo - Invalid (priority di luar enum)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Test priority salah\",\n  \"priority\": \"urgent\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/todos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos"] },
        "description": "Ekspektasi: 400 Bad Request, message 'priority harus salah satu dari: low, medium, high'. Menguji @IsIn."
      }
    },
    {
      "name": "5. Create Todo - Invalid (field asing / forbidNonWhitelisted)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Test field asing\",\n  \"hacker\": true\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/todos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos"] },
        "description": "Ekspektasi: 400 Bad Request, message 'property hacker should not exist'. Menguji forbidNonWhitelisted pada ValidationPipe global."
      }
    },
    {
      "name": "6. Get All Todos",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/todos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos"] },
        "description": "Ekspektasi: 200 OK, array berisi 2 todo (dari request #1 dan #2)."
      }
    },
    {
      "name": "7. Get All Todos - Filter completed=false",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/todos?completed=false",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "todos"],
          "query": [{ "key": "completed", "value": "false" }]
        },
        "description": "Ekspektasi: 200 OK, kedua todo muncul (belum ada yang completed)."
      }
    },
    {
      "name": "8. Get All Todos - Filter completed=true",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/todos?completed=true",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "todos"],
          "query": [{ "key": "completed", "value": "true" }]
        },
        "description": "Ekspektasi: 200 OK, array kosong [] (belum ada yang ditandai selesai)."
      }
    },
    {
      "name": "9. Get Todo By ID - Valid",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/todos/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos", "1"] },
        "description": "Ekspektasi: 200 OK, detail todo id=1."
      }
    },
    {
      "name": "10. Get Todo By ID - Not Found",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/todos/999", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos", "999"] },
        "description": "Ekspektasi: 404 Not Found, message 'Todo dengan ID 999 tidak ditemukan'."
      }
    },
    {
      "name": "11. Get Todo By ID - Format ID salah",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/todos/abc", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos", "abc"] },
        "description": "Ekspektasi: 400 Bad Request dari ParseIntPipe, message 'Validation failed (numeric string is expected)'."
      }
    },
    {
      "name": "12. Update Todo - Valid (tandai selesai)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"completed\": true\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/todos/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos", "1"] },
        "description": "Ekspektasi: 200 OK, todo id=1 sekarang completed=true."
      }
    },
    {
      "name": "13. Update Todo - Valid (ubah title & priority)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Beli bahan praktikum (revisi)\",\n  \"priority\": \"medium\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/todos/2", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos", "2"] },
        "description": "Ekspektasi: 200 OK, title dan priority todo id=2 berubah, field lain tidak berubah."
      }
    },
    {
      "name": "14. Update Todo - Not Found",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"completed\": true\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/todos/999", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos", "999"] },
        "description": "Ekspektasi: 404 Not Found."
      }
    },
    {
      "name": "15. Update Todo - Invalid (priority salah)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"priority\": \"urgent\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/todos/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos", "1"] },
        "description": "Ekspektasi: 400 Bad Request. Validasi DTO tetap berlaku walau lewat PartialType (UpdateTodoDto)."
      }
    },
    {
      "name": "16. Delete Todo - Valid",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/todos/2", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos", "2"] },
        "description": "Ekspektasi: 200 OK, message 'Todo dengan ID 2 berhasil dihapus'."
      }
    },
    {
      "name": "17. Delete Todo - Not Found (sudah dihapus)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/todos/2", "host": ["{{baseUrl}}"], "path": ["api", "v1", "todos", "2"] },
        "description": "Ekspektasi: 404 Not Found, karena id=2 sudah dihapus di step sebelumnya."
      }
    }
  ]
}
